ScreenManager:
    HomeScreen:
    CalculatorScreen:

<HomeScreen>:
    name: "home"

    BoxLayout:
        orientation: "vertical"

        Label:
            text: "Geometry Calculator"

        Button:
            text: "Circle"
            on_release:
                app.root.current = "calculator"


<CalculatorScreen>:
    name: "calculator"

    BoxLayout:
        orientation: "vertical"
        padding: 10
        spacing: 10

        Label:
            text: "Circle Calculator"

        TextInput:
            id: radius
            hint_text: "Enter Radius"
            multiline: False

        Button:
            text: "Calculate"
            on_release:
                root.calculate()

        Label:
            text: root.result

        Button:
            text: "Back"
            on_release:
                app.root.current = "home"